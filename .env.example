# Copy this file to `.env` for local development.
# `open-runo-router` / `open-runo-gateway` read these via
# `open_runo_core::Config::from_env`. See DEVELOPMENT.md for details.

# local | development | staging | production
OPEN_RUNO_ENV=local

# Address the Gateway Router binds to.
OPEN_RUNO_BIND_ADDR=0.0.0.0:8080

# tracing / tracing-subscriber EnvFilter directive, e.g. info, debug,
# open_runo_router=debug,info
OPEN_RUNO_LOG_LEVEL=info

# Only needed when building/running open-runo-db with the `postgres` feature.
# See docker-compose.yml for a matching local Postgres instance.
DATABASE_URL=postgres://postgres:openruno@localhost:5432/postgres

# Rate limit applied by open-runo-router's rate-limiting middleware
# (see crates/open-runo-router/src/middleware_hyper.rs).
OPEN_RUNO_RATE_LIMIT_MAX_REQUESTS=120
OPEN_RUNO_RATE_LIMIT_WINDOW_SECS=60

# Optional: OTLP HTTP endpoint (e.g. an OpenTelemetry Collector, Jaeger, or
# Tempo listening on its OTLP HTTP port) to export traces to. Unset by
# default -- tracing stays console-only (JSON to stdout) with no collector
# required for local development. See crates/open-runo-observability.
# OPEN_RUNO_OTLP_ENDPOINT=http://localhost:4318
